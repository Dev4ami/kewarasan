# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/kewarasan

# Token bot dari @BotFather
TELOXIDE_TOKEN=123456:ABC-your-token-here

# Port web dashboard (opsional, default 3000; image Docker default 8775)
WEB_PORT=3000

# Login dashboard (cookie session + halaman /login).
# DASHBOARD_PASSWORD tidak diset = dashboard terbuka (buat dev lokal).
# Diset = buka dashboard diarahkan ke /login, butuh password dulu.
# DASHBOARD_USER opsional, default "kewarasan".
# DASHBOARD_USER=kewarasan
# DASHBOARD_PASSWORD=ganti-di-prod
